# Copy to .env and fill in. Only OPENAI_API_KEY is required for the default (Chroma) backend.
OPENAI_API_KEY=sk-...

# Models
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Vector backend: "chroma" (zero-setup, default) or "pgvector"
VECTOR_BACKEND=chroma
CHROMA_PATH=.chroma
COLLECTION=knowledge_base

# Only used when VECTOR_BACKEND=pgvector
PG_DSN=postgresql://postgres:postgres@localhost:5432/rag

# Retrieval
TOP_K=5
MAX_GENERATION_ATTEMPTS=2
